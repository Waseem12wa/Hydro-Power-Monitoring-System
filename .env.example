# Groq AI API Key (Get your free API key from: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Session Secret (Use a strong random string for production)
SESSION_SECRET=your_secure_random_string_here

# Plant API Key (For external devices to push real-time data)
PLANT_API_KEY=hydro_plant_2026_secure_key

# Server Port
PORT=3000

# Node Environment
NODE_ENV=development
